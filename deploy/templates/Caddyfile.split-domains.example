{
	# 全局配置（Ubuntu 自带 Caddy 2.6+ 勿写 auto_https on，见文档）
	email ops@example.com
}

(secure_headers) {
	header {
		-X-Powered-By
		-Server
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
}

# C 端
www.example.com {
	import secure_headers

	# JSON 访问日志：按大小滚动 + 保留份数/时长。按「自然日」统计由日报脚本根据行内 ts 过滤（不要求单日单文件）。
	# 若 `roll_local_time` 在你本机 Caddy 版本上报错，删掉该行后再 `caddy validate`。
	log {
		output file /var/log/caddy/www-access.json {
			roll_size     100MiB
			roll_keep     30
			roll_keep_for 720h
			roll_local_time
		}
		format json
	}

	# nextjs compose: 127.0.0.1:13000:3000
	reverse_proxy 127.0.0.1:13000
}

# 后台（反代层门禁）
op.example.com {
	import secure_headers

	log {
		output file /var/log/caddy/op-access.json {
			roll_size     100MiB
			roll_keep     30
			roll_keep_for 720h
			roll_local_time
		}
		format json
	}

	# 1) query token 校验通过：发 cookie，并去参重定向
	@gate_by_query expression `
		{http.request.uri.query.entry_token} == "{$OP_GATE_TOKEN}" ||
		("{$OP_GATE_TOKEN_OLD}" != "" && {http.request.uri.query.entry_token} == "{$OP_GATE_TOKEN_OLD}")
	`
	handle @gate_by_query {
		header Set-Cookie "admin_gate={$OP_GATE_TOKEN}; Max-Age=2592000; Path=/; HttpOnly; Secure; SameSite=Lax"
		redir {path} 302
	}

	# 2) cookie 合法：放行 + 滑动续期
	@gate_by_cookie expression `
		{http.request.cookie.admin_gate} == "{$OP_GATE_TOKEN}" ||
		("{$OP_GATE_TOKEN_OLD}" != "" && {http.request.cookie.admin_gate} == "{$OP_GATE_TOKEN_OLD}")
	`
	handle @gate_by_cookie {
		header Set-Cookie "admin_gate={$OP_GATE_TOKEN}; Max-Age=2592000; Path=/; HttpOnly; Secure; SameSite=Lax"
		# php-server compose: 127.0.0.1:18080:80
		reverse_proxy 127.0.0.1:18080
	}

	# 3) 未通过门禁：404
	handle {
		respond "Not Found" 404
	}
}

# 运维：日报 / 指标仪表盘静态站（与 op 相同的 Query + Cookie 门禁模式；cookie 名 maint_gate；MAINT_GATE_TOKEN 须与 OP_GATE_TOKEN 为不同随机串）
# 测试环境：`maint.dinngoo.xyz`。其它部署请改本段 `server` 域名；{$MAINT_STATIC_ROOT} 指向宿主机日报输出目录（与 server-maintain 的 REPORT_DIR 一致）。
maint.dinngoo.xyz {
	import secure_headers

	log {
		output file /var/log/caddy/maint-access.json {
			roll_size     50MiB
			roll_keep     14
			roll_keep_for 720h
			roll_local_time
		}
		format json
	}

	@maint_gate_by_query expression `
		{http.request.uri.query.entry_token} == "{$MAINT_GATE_TOKEN}" ||
		("{$MAINT_GATE_TOKEN_OLD}" != "" && {http.request.uri.query.entry_token} == "{$MAINT_GATE_TOKEN_OLD}")
	`
	handle @maint_gate_by_query {
		header Set-Cookie "maint_gate={$MAINT_GATE_TOKEN}; Max-Age=2592000; Path=/; HttpOnly; Secure; SameSite=Lax"
		redir {path} 302
	}

	@maint_gate_by_cookie expression `
		{http.request.cookie.maint_gate} == "{$MAINT_GATE_TOKEN}" ||
		("{$MAINT_GATE_TOKEN_OLD}" != "" && {http.request.cookie.maint_gate} == "{$MAINT_GATE_TOKEN_OLD}")
	`
	handle @maint_gate_by_cookie {
		header Set-Cookie "maint_gate={$MAINT_GATE_TOKEN}; Max-Age=2592000; Path=/; HttpOnly; Secure; SameSite=Lax"
		root * {$MAINT_STATIC_ROOT}
		# 启用目录列表：运维静态站有 entry_token + cookie，便于点选 daily-*.html / dashboard.html
		file_server browse
	}

	handle {
		respond "Not Found" 404
	}
}
