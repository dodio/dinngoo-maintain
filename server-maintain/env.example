# 复制为 .env；勿提交含秘钥的 .env
# 约定：本目录在 /srv/dinngoo-room/dinngoo-maintain/server-maintain（见 deploy/SERVER-MAINTAIN-部署.md）

# ---------- 日报（generate-daily-report.mjs）----------
# Caddy JSON 访问日志 glob（单行 JSON；支持单段 *）
CADDY_WWW_ACCESS_GLOB=/var/log/caddy/www-access*.json
CADDY_OP_ACCESS_GLOB=/var/log/caddy/op-access*.json
# SSH 审计（Ubuntu 常见路径；无权限则报告中标注未采集）
AUTH_LOG_PATH=/var/log/auth.log

# 报表输出目录（与 Caddy maint.dinngoo.xyz 的 MAINT_STATIC_ROOT 一致；其它环境按实际子域）
REPORT_DIR=/var/www/maint-static
# 可选；默认 daily-YYYY-MM-DD.json
# REPORT_BASENAME=daily

# 访问日志异常明细：抽样上限（可选）
# REPORT_ANOMALY_MAX_COLLECT=12000
# REPORT_ANOMALY_MAX_ROWS=350
# REPORT_ABNORMAL_TOP_PATHS=25

# 慢请求（Caddy JSON 的 duration 字段，单位秒；默认 ≥3s 计为慢请求）
# REPORT_SLOW_THRESHOLD_SEC=3
# REPORT_SLOW_MAX_COLLECT=8000
# REPORT_SLOW_MAX_ROWS=60

# 附录 docker logs（日报生成时执行；需本机 docker 支持 --since/--until，且运行用户有权限）
# REPORT_ATTACH_DOCKER_LOGS=1
# REPORT_DOCKER_LOG_SERVICES=php-server-php-1,dinngoo-site-next-1
# REPORT_DOCKER_LOG_TIMEOUT_MS=90000
# REPORT_DOCKER_LOG_GREP=Error|Fatal|Exception|panic|PHP Fatal|Unhandled

# ---------- 指标（collect-metrics.mjs）----------
METRICS_JSON_PATH=
# 若为空则默认 $REPORT_DIR/metrics.json

# 与 mysql-full-backup.sh 输出一致，用于展示「最新备份」
BACKUP_DIR=/var/backups/mysql-dinngoo
BACKUP_GLOB=*.sql.gz

# ---------- MySQL 备份（mysql-full-backup.sh）----------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
# 使用导出；勿写入仓库
# MYSQL_PASSWORD=
MYSQL_DATABASE=room_controll
# BACKUP_DIR=/var/backups/mysql-dinngoo
BACKUP_KEEP_DAYS=14
# 宿主机未安装 mysqldump 时，改为在 mysql 容器内导出（填 php-server 的 compose 路径）
# MYSQLDUMP_COMPOSE_FILE=/srv/dinngoo-room/php-server/docker-compose.prod.yml

# ---------- Token 轮换（rotate-gate-tokens.mjs / dinngoo-rotate-gate-tokens）----------
# 与 install-dinngoo-server-maintain-wrappers.sh 写入的 systemd EnvironmentFile 一致（勿用旧名 caddy.env 除非你真用该路径）
CADDY_ENV_FILE=/etc/caddy/env.deploy
# --write 时备份 Caddy 环境文件与 Caddyfile 的目录：默认同级于 BACKUP_DIR 的兄弟目录 caddy/（如 .../backups/mysql → .../backups/caddy）
# CADDY_ROTATE_BACKUP_DIR=/srv/dinngoo-room/backups/caddy
# --write 时额外备份 Caddyfile；默认 /etc/caddy/Caddyfile，不在则跳过
# CADDYFILE_PATH=/etc/caddy/Caddyfile

# ---------- Docker 容器日志扫描（analyze-docker-logs.mjs）----------
# 逗号分隔容器名（与 docker ps 一致，如 php-server-nginx-1）
# DOCKER_LOG_CONTAINERS=php-server-mysql-1,php-server-php-1,php-server-nginx-1
# 或直接读 json-file（路径中一个 *）
# DOCKER_JSON_LOG_GLOB=/var/lib/docker/containers/ab12...hash.../*-json.log
# 报表日（可选，默认昨天）
# DOCKER_LOG_DATE=2026-05-07
# 追加关键词（小写逗号分隔，与内置列表合并）
# DOCKER_LOG_KEYWORDS=prisma,nuxt
