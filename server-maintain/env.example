# 复制为 .env 或在 shell 中 export；勿提交含秘钥的 .env

# ---------- 日报（generate-daily-report.mjs）----------
# Caddy JSON 访问日志 glob（单行 JSON；支持单段 *）
CADDY_WWW_ACCESS_GLOB=/var/log/caddy/www-access*.json
CADDY_OP_ACCESS_GLOB=/var/log/caddy/op-access*.json
# SSH 审计（Ubuntu 常见路径；无权限则报告中标注未采集）
AUTH_LOG_PATH=/var/log/auth.log

# 报表输出目录（与 Caddy MAINT_STATIC_ROOT 一致）
REPORT_DIR=/var/www/maint-static
# 可选；默认 daily-YYYY-MM-DD.html
# REPORT_BASENAME=daily

# ---------- 指标（collect-metrics.mjs）----------
METRICS_JSON_PATH=
# 若为空则默认 $REPORT_DIR/metrics.json

# 与 mysql-full-backup.sh 输出一致，用于展示「最新备份」
BACKUP_DIR=/var/backups/mysql-dinggu
BACKUP_GLOB=*.sql.gz

# ---------- MySQL 备份（mysql-full-backup.sh）----------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
# 使用导出；勿写入仓库
# MYSQL_PASSWORD=
MYSQL_DATABASE=room_controll
# BACKUP_DIR=/var/backups/mysql-dinggu
BACKUP_KEEP_DAYS=14

# ---------- Token 轮换（rotate-gate-tokens.mjs）----------
# 若设置且非 dry-run，将写回该文件（Systemd 下 Caddy 的 EnvironmentFile）
# CADDY_ENV_FILE=/etc/caddy/caddy.env

# ---------- Docker 容器日志扫描（analyze-docker-logs.mjs）----------
# 逗号分隔容器名（与 docker ps 一致，如 php-server-nginx-1）
# DOCKER_LOG_CONTAINERS=php-server-mysql-1,php-server-php-1,php-server-nginx-1
# 或直接读 json-file（路径中一个 *）
# DOCKER_JSON_LOG_GLOB=/var/lib/docker/containers/ab12...hash.../*-json.log
# 报表日（可选，默认昨天）
# DOCKER_LOG_DATE=2026-05-07
# 追加关键词（小写逗号分隔，与内置列表合并）
# DOCKER_LOG_KEYWORDS=prisma,nuxt
